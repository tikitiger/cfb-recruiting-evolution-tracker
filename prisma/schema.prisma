generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Team {
  id           String @id @default(cuid())
  name         String @unique
  shortName    String?
  nickname     String?
  conference   String
  division     String?
  logoUrl      String?
  primaryColor String?

  stats     TeamSeasonStat[]
  pipelines TeamPipeline[]
}

model Season {
  id         String   @id @default(cuid())
  year       Int      @unique
  label      String
  importedAt DateTime @default(now())
  sourceFile String?

  stats     TeamSeasonStat[]
  settings  SeasonSettings?
  pipelines TeamPipeline[]
}

model SeasonSettings {
  id       String @id @default(cuid())
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId String @unique

  cpuTransferChance  Int?
  userTransferChance Int?
  maxTransfersPerTeam Int?
  recruitFlipping    Boolean?
  skillLevel         String?
  progressionFreq    String?
  talentProgressSpeed String?
  xpPenalty          Int?

  xpQB  Int?
  xpHB  Int?
  xpWR  Int?
  xpTE  Int?
  xpT   Int?
  xpG   Int?
  xpC   Int?
  xpDE  Int?
  xpDT  Int?
  xpOLB Int?
  xpMLB Int?
  xpCB  Int?
  xpFS  Int?
  xpSS  Int?
  xpK   Int?
  xpP   Int?

  unsignedTotal     Int?
  unsignedFiveStar  Int?
  unsignedFourStar  Int?
  unsignedThreeStar Int?
  unsignedTwoStar   Int?
  unsignedOneStar   Int?
  unsignedHS        Int?
  unsignedTransfer  Int?

  unsignedHSFiveStar   Int?
  unsignedHSFourStar   Int?
  unsignedHSThreeStar  Int?
  unsignedHSTwoStar    Int?
  unsignedHSOneStar    Int?
  unsignedXferFiveStar  Int?
  unsignedXferFourStar  Int?
  unsignedXferThreeStar Int?
  unsignedXferTwoStar   Int?
  unsignedXferOneStar   Int?
}

model TeamSeasonStat {
  id       String @id @default(cuid())
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId String

  overall        Int?
  prestige       Int?
  prestigeRank   Int?
  recruitingRank Int?
  teamRank       Int?

  wins   Int?
  losses Int?

  transfersIn  Int?
  transfersOut Int?

  recruitCount     Int?
  unsignedRecruits Int?
  rosterSize       Int?

  fiveStars  Int?
  fourStars  Int?
  threeStars Int?
  twoStars   Int?
  oneStars   Int?

  fiveStarsHS  Int?
  fourStarsHS  Int?
  threeStarsHS Int?
  twoStarsHS   Int?
  oneStarsHS   Int?

  fiveStarsXfer  Int?
  fourStarsXfer  Int?
  threeStarsXfer Int?
  twoStarsXfer   Int?
  oneStarsXfer   Int?

  hsRecruits       Int?
  transferRecruits Int?

  gradeAtmosphere  String?
  gradeBrand       String?
  gradeBudget      String?
  gradeTraditions  String?
  gradeConference  String?
  gradeFacilities  String?
  facilitiesScore  Int?
  gradeAcademic    String?
  gradeCampus      String?
  gradeCoachStability String?
  gradeCoachPrestige  String?
  gradeChampion    String?
  gradeProQB       String?
  gradeProRB       String?
  gradeProWR       String?
  gradeProTE       String?
  gradeProOL       String?
  gradeProDL       String?
  gradeProLB       String?
  gradeProDB       String?
  gradeProK        String?
  gradeProP        String?
  avgGrade         Float?

  coachName      String?
  coachArchetype String?
  coachLevel     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, seasonId])
}

model TeamPipeline {
  id       String @id @default(cuid())
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId String
  pipeline String
  level    String
  value    Int

  @@unique([teamId, seasonId, pipeline])
}

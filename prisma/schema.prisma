generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Team {
  id           String @id @default(cuid())
  name         String @unique
  shortName    String?
  nickname     String?
  conference   String
  division     String?
  logoUrl      String?
  primaryColor String?

  stats TeamSeasonStat[]
}

model Season {
  id         String   @id @default(cuid())
  year       Int      @unique
  label      String
  importedAt DateTime @default(now())
  sourceFile String?

  stats    TeamSeasonStat[]
  settings SeasonSettings?
}

model SeasonSettings {
  id       String @id @default(cuid())
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId String @unique

  cpuTransferChance  Int?
  userTransferChance Int?
  maxTransfersPerTeam Int?
  recruitFlipping    Boolean?
  skillLevel         String?
  progressionFreq    String?
  talentProgressSpeed String?
  xpPenalty          Int?

  xpQB  Int?
  xpHB  Int?
  xpWR  Int?
  xpTE  Int?
  xpT   Int?
  xpG   Int?
  xpC   Int?
  xpDE  Int?
  xpDT  Int?
  xpOLB Int?
  xpMLB Int?
  xpCB  Int?
  xpFS  Int?
  xpSS  Int?
  xpK   Int?
  xpP   Int?

  unsignedTotal    Int?
  unsignedFiveStar Int?
  unsignedFourStar Int?
  unsignedThreeStar Int?
  unsignedTwoStar  Int?
  unsignedOneStar  Int?
  unsignedHS       Int?
  unsignedTransfer Int?
}

model TeamSeasonStat {
  id       String @id @default(cuid())
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId String

  overall        Int?
  prestige       Int?
  prestigeRank   Int?
  recruitingRank Int?
  teamRank       Int?

  wins   Int?
  losses Int?

  transfersIn  Int?
  transfersOut Int?

  recruitCount     Int?
  unsignedRecruits Int?
  rosterSize       Int?

  fiveStars  Int?
  fourStars  Int?
  threeStars Int?
  twoStars   Int?
  oneStars   Int?

  hsRecruits       Int?
  transferRecruits Int?

  gradeAtmosphere  String?
  gradeBrand       String?
  gradeBudget      String?
  gradeTraditions  String?
  gradeConference  String?
  avgGrade         Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, seasonId])
}
